<?xml version="1.0" encoding="utf-8"?>
<subsection xml:id="course_prerequisites" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Course Prerequisites</title>
  <p>
    Successful completion of Math 1003 OR successful completion of Math 1013 OR Placement by Exam OR Math ACT score greater than or equal to 26 OR Math SAT score greater than or equal to 610.
  </p>
</subsection>
